{
    "name": "cinestream",
    "version": "1.0.0",
    "description": "Website xem phim trực tuyến với giao diện hiện đại",
    "main": "server.js",
    "scripts": {
        "start": "node server.js",
        "dev": "nodemon server.js",
        "proxy": "node proxy-server.js",
        "start-all": "concurrently \"npm start\" \"npm run proxy\"",
        "build:css": "node node_modules/tailwindcss/lib/cli.js -i css/tailwind-input.css -o css/tailwind.min.css --minify",
        "watch:css": "node node_modules/tailwindcss/lib/cli.js -i css/tailwind-input.css -o css/tailwind.min.css --watch"
    },
    "keywords": [
        "movie",
        "streaming",
        "cinema"
    ],
    "author": "",
    "license": "MIT",
    "dependencies": {
        "axios": "^1.13.6",
        "composio-core": "^0.5.39",
        "cors": "^2.8.5",
        "express": "^4.18.2",
        "jimp": "^0.16.13"
    },
    "devDependencies": {
        "@tailwindcss/forms": "^0.5.11",
        "concurrently": "^8.2.2",
        "nodemon": "^3.0.1",
        "tailwindcss": "^3.4.19"
    }
}
